generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamRole {
  owner
  admin
  member
  viewer

  @@map("team_role")
}

model User {
  id           String           @id @default(uuid()) @db.Uuid
  email        String           @unique @db.VarChar(320)
  passwordHash String           @map("password_hash") @db.VarChar(255)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  memberships  TeamMembership[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  tokenHash     String   @unique @map("token_hash") @db.Char(64)
  csrfTokenHash String   @map("csrf_token_hash") @db.Char(64)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Team {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @db.VarChar(100)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  memberships TeamMembership[]
  projects    Project[]

  @@map("teams")
}

model TeamMembership {
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      TeamRole
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  teamId       String        @map("team_id") @db.Uuid
  name         String        @db.VarChar(100)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  environments Environment[]

  @@unique([teamId, name])
  @@index([teamId])
  @@map("projects")
}

model Environment {
  id         String      @id @default(uuid()) @db.Uuid
  projectId  String      @map("project_id") @db.Uuid
  name       String      @db.VarChar(100)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ingestKeys IngestKey[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("environments")
}

model IngestKey {
  id            String      @id @default(uuid()) @db.Uuid
  environmentId String      @map("environment_id") @db.Uuid
  name          String      @db.VarChar(100)
  prefix        String      @unique @db.VarChar(24)
  secretHash    String      @unique @map("secret_hash") @db.Char(64)
  createdAt     DateTime    @default(now()) @map("created_at")
  lastUsedAt    DateTime?   @map("last_used_at")
  revokedAt     DateTime?   @map("revoked_at")
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@index([environmentId, revokedAt])
  @@map("ingest_keys")
}
